{
  "name": "kuberemoteweb",
  "version": "1.0.0",
  "description": "Kubernetes port-forward with embedded browser",
  "main": "main.js",
  "scripts": {
    "start":         "electron .",
    "test":          "jest",
    "test:watch":    "jest --watch",
    "test:coverage": "jest --coverage",
    "build:win":            "electron-builder --win",
    "build:mac":            "electron-builder --mac",
    "build:linux":          "electron-builder --linux",
    "build:win:portable":   "electron-builder --win portable",
    "build:mac:zip":        "electron-builder --mac zip",
    "build:linux:appimage": "electron-builder --linux AppImage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/config.js"]
  },
  "devDependencies": {
    "electron":         "^31.0.0",
    "electron-builder": "^24.13.0",
    "jest":             "^29.7.0"
  },
  "build": {
    "appId":       "com.matteogazzadi.kuberemoteweb",
    "productName": "KubeRemoteWeb",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "src/**"],
    "win": {
      "target": ["nsis", "portable"],
      "extraResources": [{ "from": "bin/kubectl.exe", "to": "kubectl.exe" }]
    },
    "mac": {
      "target": ["dmg", "zip"],
      "extraResources": [{ "from": "bin/kubectl", "to": "kubectl" }]
    },
    "linux": {
      "target": ["AppImage"],
      "extraResources": [{ "from": "bin/kubectl", "to": "kubectl" }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    }
  }
}
